{
  "project_name": "Golden-X-Host STR Platform",
  "theme_and_archetype": {
    "theme": "LIGHT",
    "archetype": "1_organic_and_earthy",
    "rationale": "For a Short Term Renting (STR) platform handling residential, commercial, and event spaces, we need to establish trust, warmth, and a sensory experience. Archetype 1 provides a grounded, inviting look that balances professional dashboard functionality with the emotional resonance required for high-end property rentals."
  },
  "typography": {
    "headings": {
      "font_family": "Manrope",
      "weights": ["light", "bold", "extrabold"],
      "tracking": "tracking-tight",
      "classes": "font-sans font-extrabold tracking-tight text-charcoal",
      "h1_max_size": "text-5xl lg:text-6xl"
    },
    "body": {
      "font_family": "Manrope",
      "weights": ["regular", "medium", "semibold"],
      "tracking": "tracking-normal",
      "classes": "font-sans text-base leading-relaxed text-charcoal-light"
    },
    "labels": {
      "classes": "text-xs font-bold uppercase tracking-[0.2em] text-sage-dark"
    },
    "imports": [
      "@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap');"
    ]
  },
  "colors": {
    "background": {
      "default": "#FDFCF8",
      "stone": "#F5F5F0",
      "white": "#FFFFFF"
    },
    "foreground": {
      "default": "#2C2C2C",
      "muted": "#5C5C5C",
      "light": "#8C8C8C"
    },
    "primary": {
      "default": "#C05C4F",
      "hover": "#A94E42",
      "foreground": "#FFFFFF"
    },
    "secondary": {
      "default": "#788574",
      "hover": "#647160",
      "foreground": "#FFFFFF"
    },
    "border": "#E5E5DF",
    "surface": {
      "card": "#FFFFFF",
      "input": "#F5F5F0"
    },
    "tailwind_config_extension": {
      "colors": {
        "sand": {
          "50": "#FDFCF8",
          "100": "#FBF9F2",
          "200": "#F5F2E6",
          "300": "#EBE5D3",
          "400": "#DCD3B9",
          "500": "#CCBE9E",
          "600": "#BAA783",
          "700": "#A28D67",
          "800": "#857355",
          "900": "#6C5E47"
        },
        "charcoal": {
          "DEFAULT": "#2C2C2C",
          "light": "#5C5C5C",
          "muted": "#8C8C8C"
        },
        "terracotta": {
          "DEFAULT": "#C05C4F",
          "hover": "#A94E42",
          "light": "#D8897E"
        },
        "sage": {
          "DEFAULT": "#788574",
          "dark": "#525C4F",
          "light": "#9FAB9C"
        },
        "stone": "#F5F5F0"
      }
    }
  },
  "spacing_and_layout": {
    "philosophy": "Generous spacing. Internal padding must prevent text collision.",
    "container_padding": "p-6 md:p-8 lg:p-12",
    "grids": {
      "dashboard": "grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6",
      "marketing_hero": "grid grid-cols-1 md:grid-cols-12 gap-8"
    },
    "card_radius": "rounded-xl",
    "button_radius": "rounded-lg",
    "input_radius": "rounded-lg"
  },
  "surfaces_and_shadows": {
    "dashboard_cards": {
      "background": "bg-white",
      "border": "border border-stone",
      "shadow": "shadow-sm",
      "hover": "hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
    },
    "headers": {
      "glass": "bg-white/80 backdrop-blur-xl border-b border-stone",
      "solid": "bg-white border-b border-stone"
    }
  },
  "components_strategy": {
    "buttons": "Flat design. Primary uses Terracotta. Secondary uses Sage or transparent with border. Minimal shadows. Text must be readable (min 4.5:1).",
    "inputs": "Filled background (stone) rather than heavily bordered. Soft borders on focus (focus:ring-terracotta).",
    "charts": "Recharts or Shadcn Charts. Use Sage and Terracotta variants for data representation. Keep grids light (stone).",
    "tables": "Clean, flat. No vertical borders. Generous row padding (py-4).",
    "navigation": "Clear hierarchy. Active states use Terracotta text or underline. Top navigation with white/glass background."
  },
  "icons_and_assets": {
    "library": "lucide-react",
    "stroke_width": "1.5",
    "style": "clean, consistent sizing"
  },
