# Golden Rich Stay backend env template
# Copy to .env and replace placeholders. Never commit .env.

# --- Required: database ---
DATABASE_TYPE=postgres
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/str_project

# Legacy Mongo fallback only. Leave blank when DATABASE_TYPE=postgres.
MONGO_URL=
DB_NAME=propnest_db

# --- Required: auth ---
JWT_SECRET_KEY=replace-with-a-32-plus-byte-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Seeded admin account ---
# Set different values in local and server .env files.
# ADMIN_RESET_PASSWORD=true updates the existing admin password on next backend startup.
ADMIN_EMAIL=admin@goldenrichstay.com
ADMIN_PASSWORD=admin@123
ADMIN_NAME=Golden Rich Stay Admin
ADMIN_RESET_PASSWORD=false

# --- CORS / public URLs ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PUBLIC_BACKEND_URL=http://localhost:8001
PUBLIC_FRONTEND_URL=http://localhost:3000

# --- GoldenRich OAuth2 / SSO ---
# GoldenRich must register this exact callback URL:
# Local:  http://localhost:8001/api/auth/sso/goldenrich/callback
# Server: https://api.your-domain.com/api/auth/sso/goldenrich/callback
GOLDENRICH_OAUTH_CLIENT_ID=
GOLDENRICH_OAUTH_CLIENT_SECRET=
GOLDENRICH_OAUTH_AUTHORIZE_URL=
GOLDENRICH_OAUTH_TOKEN_URL=
GOLDENRICH_OAUTH_USERINFO_URL=
# Keep scopes minimal, but GoldenRich may require a custom scope to expose
# mobile, lg_code, and employee_code in userinfo.
GOLDENRICH_OAUTH_SCOPE=openid profile email phone
GOLDENRICH_OAUTH_REDIRECT_URI=
# Set false only for plain-http local testing.
SSO_COOKIE_SECURE=false

# --- Razorpay payments ---
# UAT option A: set only RAZORPAY_KEY_ID to a Razorpay test key to show
# Razorpay Checkout while backend settlement remains mock.
# UAT option B: set both test key + test secret for full Razorpay test signature flow.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Keep RazorpayX payouts mocked in UAT unless you have a real RazorpayX account.
# Set false only after adding RAZORPAYX_ACCOUNT_NUMBER and RazorpayX access.
RAZORPAYX_DEMO_MODE=true
RAZORPAYX_ACCOUNT_NUMBER=

# --- MSG91 SMS / WhatsApp ---
# Use true on EC2/staging until real MSG91 credentials are available.
MSG91_DEMO_MODE=true
MSG91_AUTHKEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=
MSG91_OTP_DEFAULT_NAME=Customer
MSG91_OTP_NAME_VARIABLE=name
MSG91_OTP_CODE_VARIABLE=otp
MSG91_WHATSAPP_TEMPLATE_ID=

# --- Email / MSG91 ---
EMAIL_DEMO_MODE=true
EMAIL_PROVIDER=msg91
MSG91_EMAIL_AUTHKEY=
MSG91_EMAIL_DOMAIN=
MSG91_EMAIL_API_URL=https://control.msg91.com/api/v5/email/send
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=X-Space360
SUPPORT_EMAIL=support@x-space360.in
SUPPORT_PHONE=+91XXXXXXXXXX
MSG91_EMAIL_TEMPLATE_HOST_REGISTRATION=
MSG91_EMAIL_TEMPLATE_CUSTOMER_REGISTRATION=
MSG91_EMAIL_TEMPLATE_PASSWORD_RESET=
MSG91_EMAIL_TEMPLATE_HOST_DOCUMENTS_REJECTED=
MSG91_EMAIL_TEMPLATE_HOST_APPROVED=
MSG91_EMAIL_TEMPLATE_PROPERTY_APPROVED=
MSG91_EMAIL_TEMPLATE_PROPERTY_REJECTED=
MSG91_EMAIL_TEMPLATE_SUBSCRIPTION_ACTIVATED=
MSG91_EMAIL_TEMPLATE_SUBSCRIPTION_FAILED=
MSG91_EMAIL_TEMPLATE_INVOICE_SENT=
MSG91_EMAIL_TEMPLATE_BOOKING_CONFIRMATION=
MSG91_EMAIL_TEMPLATE_BOOKING_REMINDER=
MSG91_EMAIL_TEMPLATE_REVIEW_REMINDER=
MSG91_EMAIL_TEMPLATE_REFUND=
MSG91_EMAIL_TEMPLATE_BOOKING_CANCELLATION=
MSG91_EMAIL_TEMPLATE_PAYMENT_CONFIRMATION=
MSG91_EMAIL_TEMPLATE_NEW_BOOKING=
MSG91_EMAIL_TEMPLATE_TERMS_AND_CONDITIONS=
MSG91_EMAIL_TEMPLATE_PRIVACY_POLICY_UPDATE=
MSG91_EMAIL_TEMPLATE_SUBSCRIPTION_RENEWAL_REMINDER=

# --- Email SMTP fallback (only when EMAIL_PROVIDER=smtp) ---
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# --- Redis / OTP ---
REDIS_URL=redis://localhost:6379
OTP_EXPIRY_MINUTES=5
MAX_OTP_ATTEMPTS=5

# --- Durable user uploads (private S3 bucket) ---
# Leave S3_UPLOADS_BUCKET blank for local-only development.
AWS_REGION=ap-south-1
S3_UPLOADS_BUCKET=
# Keep true during migration; set false only after S3 restore/failover testing.
S3_UPLOADS_DUAL_WRITE_LOCAL=true

# --- Pricing in paise ---
REGISTRATION_FEE_AMOUNT=50000

# --- Background jobs ---
SOFT_LOCK_REAPER_INTERVAL=30
PAYOUT_SWEEP_INTERVAL=3600
ICAL_SWEEP_INTERVAL=1800
ICAL_MIN_FRESHNESS=900
REVIEW_REMINDER_INTERVAL=3600
REVIEW_REMINDER_DELAY_DAYS=1
REVIEW_REMINDER_LOOKBACK_DAYS=5
BOOKING_REMINDER_INTERVAL=3600
BOOKING_REMINDER_LEAD_DAYS=1
# Keep both false until production refund processing and reconciliation are ready.
AUTO_REFUND_ON_CANCELLATION=false
REFUND_EMAIL_ENABLED=false
AUTO_PAYOUT_ENABLED=true
AUTO_PAYOUT_BATCH_LIMIT=100
